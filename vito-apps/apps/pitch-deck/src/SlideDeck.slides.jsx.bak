    /* 7 — STOW */
    {
      id: 7, type: 'deepdive',
      title: 'STOW — Atomic Persistence Layer',
      subtitle: 'NVMe atomic write pattern — worst-case data loss: 2 seconds at instantaneous power cut',
      badge: '§4.1.4.6 HEALTH MGMT',
      stats: [
        { label: 'Flush Interval', value: '2s', desc: 'NVMe atomic writes' },
        { label: 'Max Data Loss', value: '2s', desc: 'worst-case power cut' },
