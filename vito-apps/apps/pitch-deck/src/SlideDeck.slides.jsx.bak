import React, { useState, useEffect, useCallback } from 'react';
import {
  ChevronRight,
  ChevronLeft,
  Shield,
  Zap,
  Activity,
  CheckCircle,
  Clock,
  Menu,
  Terminal,
  Cpu,
  Database,
  Radio,
  Lock,
  Target,
  Layers,
  Server,
  Satellite,
  ArrowRight,
  ArrowDown,
  Users,
  Award,
  Globe,
  Battery,
  Wifi,
  Eye,
  Wrench,
  BookOpen,
  DollarSign,
  TrendingUp,
  AlertTriangle,
  Box,
} from 'lucide-react';

const SlideDeck = () => {
  const [currentSlide, setCurrentSlide] = useState(0);
  const [showNotes, setShowNotes] = useState(false);

  const totalSlides = 15;

  const nextSlide = useCallback(() => {
    setCurrentSlide((s) => Math.min(s + 1, totalSlides - 1));
  }, []);

  const prevSlide = useCallback(() => {
    setCurrentSlide((s) => Math.max(s - 1, 0));
  }, []);

  const toggleNotes = useCallback(() => {
    setShowNotes((n) => !n);
  }, []);

  useEffect(() => {
    const handleKeyDown = (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ') {
        e.preventDefault();
        nextSlide();
      }
      if (e.key === 'ArrowLeft') prevSlide();
      if (e.key === 'n') toggleNotes();
    };
    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [nextSlide, prevSlide, toggleNotes]);

  /* ───────── SLIDE DATA ───────── */
  const slides = [
    /* 1 — TITLE */
    {
      id: 1, type: 'title',
      title: 'VITO Series-4',
      subtitle: 'Versatile Intelligence & Tactical Operations',
      tagline: 'Autonomous Edge OS for DDIL Environments — Proposed for STTR SF25D-T1201',
      meta: 'v4.7.0  ·  TRL 6  ·  12+ Months Field Validation  ·  40+ Containerized Services  ·  8 Autonomous Agents',
      notes: 'VITO is not a concept — it is running production code managing 40+ services autonomously right now. This is a technology transition opportunity, not a feasibility study pitch.',
    },
    /* 2 — PROBLEM */
    {
      id: 2, type: 'problem',
      title: 'Problem Space',
      subtitle: 'Operational constraints driving the SF25D-T1201 solicitation',
      items: [
        { icon: Globe, color: 'red', label: 'DDIL Connectivity', desc: 'Satellite/ground links degrade during solar weather, eclipse, or adversary jamming — ground-loop C2 is fragile' },
        { icon: Battery, color: 'orange', label: 'Finite Power Budget', desc: 'Eclipse cycles cut solar input to zero. Payload demands routinely exceed bus power capacity without active management' },
        { icon: Clock, color: 'yellow', label: 'Command Latency', desc: 'Ground-loop cycles (500ms–10s RT) are incompatible with real-time threat response or collision avoidance' },
        { icon: Users, color: 'purple', label: 'Operator Scaling', desc: 'Manual constellation management does not scale — solicitation requires ≥25% operator workload reduction (§3.2)' },
        { icon: AlertTriangle, color: 'red', label: 'Data Integrity', desc: 'Standard bus computers drop telemetry during power transients and resets — no atomic persistence guarantees' },
      ],
      notes: 'DDIL = Denied, Degraded, Intermittent, Limited. These are the exact failure modes the SF25D-T1201 solicitation addresses.',
    },
    /* 3 — REQUIREMENTS TRACEABILITY MATRIX */
    {
      id: 3, type: 'alignment',
      title: 'Requirements Traceability — SF25D-T1201',
      subtitle: 'Section references per solicitation. All capabilities deployed and field-validated ≥12 months.',
      rows: [
        { ref: '§3.2', area: '1', req: 'Edge architectures for autonomous low-latency decision-making', vito: 'OTTO: Local LLM (Ollama) OODA loop, <3s inference, zero ground dependency' },
        { ref: '§3.2', area: '1', req: 'Fuse, process, filter data from multiple sources/sensors', vito: 'VERA: Aggregates telemetry from 8 agents; cross-domain correlation' },
        { ref: '§3.2', area: '1', req: 'Reduce kill-chain latency ≥50%', vito: 'Onboard inference (2-3s) vs ground RT (500ms-10s+); >80% reduction measured' },
        { ref: '§3.2', area: '1', req: 'Reduce operator workload ≥25%', vito: '8-agent crew handles power/health/data/comms/recovery; humans direct, not operate' },
        { ref: '§3.2', area: '1', req: 'Resilience to data poisoning, sensor degradation, noise', vito: 'VIGIL: threshold anomaly detection; OTTO degrades gracefully to deterministic logic' },
        { ref: '§3.2', area: '1', req: 'Anomaly/maneuver detection AI/ML', vito: 'OTTO: pattern analysis via local LLM; compound failure detection across agents' },
        { ref: '§3.2', area: '1', req: 'Zero-trust for on-board computation', vito: 'GHOST: WireGuard (ChaCha20-Poly1305), JWT/TOTP, air-gap mode, per-peer identity' },
        { ref: '§3.2', area: '1', req: 'Data compression / efficient data handling', vito: 'STOW: burst sync, buffered prioritization, delta-only uploads on reconnect' },
        { ref: '§3.2', area: '3', req: 'Autonomous load-shedding under duress', vito: 'KINETIC: 4-tier cascade via cgroup freezer; freeze/thaw <100ms; 12-mo field proven' },
        { ref: '§3.2', area: '3', req: 'Hardware-agnostic flight software', vito: 'Docker containerization — runs on ARM, RISC-V, x86; any Linux-capable SoC' },
        { ref: '§3.2', area: '3', req: 'Software modularity for autonomous integration', vito: '17 mission profiles share 8 core agents; satellite bus = Profile 18, same codebase' },
        { ref: '§3.2', area: '3', req: 'All-of-vehicle autonomous optimization', vito: 'VIGIL + KINETIC + FORGE: coordinated health/power/recovery optimization loop' },
        { ref: '§3.2', area: '3', req: 'Hardware modularity for rapid tech integration', vito: 'Docker Compose: add/remove services in seconds; hot-swap profiles at runtime' },
        { ref: '§3.2', area: '3', req: 'Reconfigurability across mission profiles', vito: 'Profile selector: defense → mining → agriculture with one config delta' },
        { ref: '§3.2', area: '2', req: 'Integrated sensor-computing for persistent tracking', vito: 'Coin nodes ($25 ea): LoRa 915MHz + GPS + env sensors, onboard processing' },
        { ref: '§3.2', area: '2', req: 'Software-defined / reconfigurable payloads', vito: 'Containerized services = software-defined payloads; swap without bus firmware change' },
        { ref: '§4.1.3.1', area: 'X', req: 'Cyber Operations and Cybersecurity', vito: 'Container isolation, zero-trust mesh, encrypted comms, JSONL audit, air-gap capable' },
        { ref: '§4.1.3.2', area: 'X', req: 'Communications and Networks', vito: 'GHOST: Tailscale P2P mesh + LoRa + air-gap failover; no central infrastructure' },
        { ref: '§4.1.4.2', area: 'X', req: 'Human-Machine Teaming and Interfaces', vito: 'Crew hierarchy: operators → OTTO (natural language) → specialist agents' },
        { ref: '§4.1.4.3', area: 'X', req: 'Training and Simulation Technologies', vito: 'Mock battery mode, Docker-based sim, hardware abstraction for testing w/o real HW' },
        { ref: '§4.1.4.5', area: 'X', req: 'Advanced Systems Engineering', vito: 'TRL 6 validated; 12-mo continuous ops; documented architecture + decision trees' },
        { ref: '§4.1.4.6', area: 'X', req: 'Integrated Vehicle Health Management', vito: 'VIGIL: CPU/thermal/mem/disk/battery monitoring, threshold alerts, trending' },
        { ref: '§4.1.4.7', area: 'X', req: 'Power and Thermal Management', vito: 'KINETIC (power cascade) + VIGIL (thermal) = closed-loop P&T optimization' },
