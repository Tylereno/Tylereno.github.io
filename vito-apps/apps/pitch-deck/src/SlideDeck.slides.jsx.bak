        { name: 'OPERATIONAL TIER', color: 'emerald', icon: Activity, items: ['VIGIL (Health)', 'KINETIC (Power)', 'STOW (Data)', 'GHOST (Network)', 'FORGE (Recovery)'], desc: 'Five specialist agents execute autonomously' },
        { name: 'INFRASTRUCTURE', color: 'blue', icon: Server, items: ['40+ Docker containers', 'Traefik routing', 'Tailscale mesh', 'Autoheal watchdog'], desc: 'Hardware-agnostic containerized services' },
