  const currentSlideData = slides[currentSlide];

  /* ───────── SHARED UI ───────── */
  const TacticalFrame = ({ children, className = '' }) => (
    <div className={`relative w-full h-full border border-gray-700/50 bg-gray-950/80 overflow-hidden rounded ${className}`}>
      <div className="absolute top-0 left-0 w-3 h-3 border-t border-l border-cyan-500/60" />
      <div className="absolute top-0 right-0 w-3 h-3 border-t border-r border-cyan-500/60" />
      <div className="absolute bottom-0 left-0 w-3 h-3 border-b border-l border-cyan-500/60" />
      <div className="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-cyan-500/60" />
      {children}
    </div>
  );

  const Badge = ({ text, color = 'cyan' }) => (
    <span className={`inline-flex items-center px-2.5 py-0.5 rounded text-[10px] font-mono font-bold tracking-wider uppercase bg-${color}-500/10 text-${color}-400 border border-${color}-500/30`}>
      {text}
    </span>
  );

  const StatCard = ({ label, value, desc }) => (
    <div className="bg-gray-900/60 border border-gray-700/50 rounded p-3 text-center">
      <div className="text-xl md:text-2xl font-bold text-cyan-400">{value}</div>
      <div className="text-xs font-bold text-white mt-1">{label}</div>
      <div className="text-[10px] text-gray-500 mt-0.5">{desc}</div>
    </div>
  );

  /* ───────── RENDERERS ───────── */
  const renderSlide = () => {
    const s = currentSlideData;
    switch (s.type) {

    /* ── TITLE ── */
    case 'title':
      return (
        <div className="flex flex-col items-center justify-center h-full text-center px-8 relative">
          <div className="absolute top-6 left-8 flex items-center space-x-2 opacity-50">
            <Shield size={14} className="text-cyan-500" />
            <span className="text-[10px] font-mono text-gray-500 tracking-widest">DISTRIBUTION A · APPROVED FOR PUBLIC RELEASE</span>
          </div>
          <div className="mb-4">
            <div className="flex items-center justify-center space-x-3 mb-2">
              <div className="w-10 h-[1px] bg-cyan-700" />
              <Satellite size={18} className="text-cyan-600" />
              <div className="w-10 h-[1px] bg-cyan-700" />
            </div>
            <span className="text-[11px] font-mono text-cyan-600 tracking-[0.2em]">SPACE FORCE STTR · SF25D-T1201 · ADAPTIVE & INTELLIGENT SPACE</span>
          </div>
          <h1 className="text-4xl md:text-5xl font-bold tracking-tight text-white mb-2">{s.title}</h1>
          <h2 className="text-base md:text-lg text-cyan-400 font-normal tracking-wide mb-3">{s.subtitle}</h2>
          <p className="text-sm text-gray-400 max-w-2xl leading-relaxed mb-6">{s.tagline}</p>
          <div className="flex flex-wrap items-center justify-center gap-2 text-[11px] font-mono text-gray-500">
            {s.meta.split('  ·  ').map((m, i) => (
              <React.Fragment key={i}>
                {i > 0 && <span className="text-gray-700">·</span>}
                <span className={m.includes('TRL') ? 'text-emerald-500 font-bold' : ''}>{m}</span>
              </React.Fragment>
            ))}
          </div>
          <div className="absolute bottom-8 flex flex-col items-center space-y-1">
            <span className="text-[11px] font-mono text-gray-500">Tyler Eno · VITO Platform · West Valley College MESA Program</span>
            <span className="text-[10px] font-mono text-gray-600">t.eno992@gmail.com · (504) 410-7420 · SAM.gov: INC-GSAFSD20703056</span>
          </div>
        </div>
      );

    /* ── PROBLEM ── */
    case 'problem':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-4">
            <Badge text="Background" color="red" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-sm mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-1 md:grid-cols-5 gap-3 items-start">
            {s.items.map((item, i) => (
              <div key={i} className={`bg-${item.color}-900/10 border border-${item.color}-800/30 rounded p-3 h-full flex flex-col`}>
                <item.icon size={20} className={`text-${item.color}-400 mb-2`} />
                <h3 className={`text-${item.color}-400 font-bold text-xs mb-1`}>{item.label}</h3>
                <p className="text-gray-400 text-[11px] leading-relaxed flex-1">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      );

    /* ── ALIGNMENT / REQUIREMENTS TRACEABILITY ── */
    case 'alignment': {
      const areaLabels = { '1': 'FA-1 Edge', '2': 'FA-2 Sensor', '3': 'FA-3 Bus', 'X': 'Cross-Cut' };
      const areaColors = { '1': 'cyan', '2': 'purple', '3': 'yellow', 'X': 'blue' };
      return (
        <div className="h-full flex flex-col px-3 py-2">
          <div className="mb-1.5 flex items-baseline justify-between">
            <div>
              <h2 className="text-lg font-bold">{s.title}</h2>
              <p className="text-gray-500 text-[10px]">{s.subtitle}</p>
            </div>
            <span className="text-emerald-500 text-[10px] font-mono font-bold">{s.rows.length} / {s.rows.length} DEPLOYED</span>
          </div>
          <div className="flex-1 overflow-auto">
            <table className="w-full text-[9px] border-collapse">
              <thead className="sticky top-0 bg-gray-950 z-10">
                <tr className="border-b border-gray-700">
                  <th className="text-left py-1 px-1 text-gray-500 font-mono w-[5%]">§</th>
                  <th className="text-left py-1 px-1 text-gray-500 font-mono w-[8%]">AREA</th>
                  <th className="text-left py-1 px-1 text-gray-500 font-mono w-[37%]">SOLICITATION REQUIREMENT</th>
                  <th className="text-left py-1 px-1 text-gray-500 font-mono w-[44%]">VITO IMPLEMENTATION</th>
                  <th className="text-center py-1 px-1 text-gray-500 font-mono w-[6%]">✓</th>
                </tr>
              </thead>
              <tbody>
                {s.rows.map((row, i) => (
                  <tr key={i} className={`border-b border-gray-800/20 ${i % 2 === 0 ? 'bg-gray-900/20' : ''}`}>
                    <td className="py-[3px] px-1 text-gray-600 font-mono text-[8px]">{row.ref}</td>
                    <td className="py-[3px] px-1">
                      <span className={`text-[7px] font-mono px-1 py-[1px] rounded bg-${areaColors[row.area]}-500/10 text-${areaColors[row.area]}-400`}>
                        {areaLabels[row.area]}
                      </span>
                    </td>
                    <td className="py-[3px] px-1 text-gray-300 leading-tight">{row.req}</td>
                    <td className="py-[3px] px-1 text-cyan-300 leading-tight font-mono text-[8px]">{row.vito}</td>
                    <td className="py-[3px] px-1 text-center">
                      <CheckCircle size={10} className="text-emerald-500 inline" />
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      );
    }

    /* ── ARCHITECTURE ── */
    case 'architecture':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-3">
            <Badge text="System Design" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 flex flex-col justify-center space-y-2">
            {s.layers.map((layer, i) => (
              <React.Fragment key={i}>
                <div className={`flex items-stretch border border-${layer.color}-700/40 bg-${layer.color}-900/5 rounded overflow-hidden`}>
                  <div className={`w-48 flex-shrink-0 bg-${layer.color}-900/20 flex items-center justify-center p-3 border-r border-${layer.color}-700/30`}>
                    <div className="text-center">
                      <layer.icon size={22} className={`text-${layer.color}-400 mx-auto mb-1`} />
                      <div className={`text-${layer.color}-400 text-[10px] font-bold font-mono`}>{layer.name}</div>
                    </div>
                  </div>
                  <div className="flex-1 p-3 flex items-center">
                    <div>
                      <div className="flex flex-wrap gap-1.5 mb-1">
                        {layer.items.map((item, j) => (
                          <span key={j} className={`text-[10px] font-mono bg-${layer.color}-500/10 text-${layer.color}-300 px-2 py-0.5 rounded border border-${layer.color}-500/20`}>{item}</span>
                        ))}
                      </div>
                      <p className="text-gray-500 text-[10px]">{layer.desc}</p>
                    </div>
                  </div>
                </div>
                {i < s.layers.length - 1 && (
                  <div className="flex justify-center">
                    <ArrowDown size={14} className="text-gray-600" />
                  </div>
                )}
              </React.Fragment>
            ))}
          </div>
          <div className="mt-2 text-center text-[10px] text-gray-600 font-mono">
            ↑ If AI layer degrades → Safety-critical operations continue autonomously ↑
          </div>
        </div>
      );

    /* ── CREW ── */
    case 'crew':
      return (
        <div className="h-full flex flex-col px-6 py-4">
          <div className="mb-3">
            <Badge text="Agent Hierarchy" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 flex flex-col">
            <div className="mb-3">
              <div className="text-[10px] font-mono text-cyan-600 tracking-widest mb-2">LEADERSHIP TIER</div>
              <div className="grid grid-cols-3 gap-3">
                {s.leadership.map((a, i) => (
                  <div key={i} className={`bg-${a.color}-900/10 border border-${a.color}-700/30 rounded p-3`}>
                    <div className="flex items-center justify-between mb-1">
                      <span className={`text-${a.color}-400 font-black text-lg`}>{a.name}</span>
                      <span className={`text-[9px] font-mono bg-${a.color}-500/20 text-${a.color}-400 px-1.5 py-0.5 rounded`}>{a.badge}</span>
                    </div>
                    <div className="text-white text-xs font-bold mb-1">{a.role}</div>
                    <div className="text-gray-500 text-[10px] leading-snug">{a.desc}</div>
                  </div>
                ))}
              </div>
            </div>
            <div className="flex justify-center my-1">
              <div className="flex items-center space-x-2 text-gray-600">
                <div className="w-16 h-[1px] bg-gray-700" />
                <ArrowDown size={12} />
                <span className="text-[9px] font-mono">DIRECTS</span>
                <ArrowDown size={12} />
                <div className="w-16 h-[1px] bg-gray-700" />
              </div>
            </div>
            <div>
              <div className="text-[10px] font-mono text-emerald-600 tracking-widest mb-2">OPERATIONS TIER</div>
              <div className="grid grid-cols-5 gap-2">
                {s.operations.map((a, i) => (
                  <div key={i} className={`bg-${a.color}-900/10 border border-${a.color}-700/30 rounded p-2.5`}>
                    <div className={`text-${a.color}-400 font-black text-sm mb-0.5`}>{a.name}</div>
                    <div className="text-white text-[10px] font-bold mb-0.5">{a.role}</div>
                    <div className="text-gray-500 text-[9px] leading-snug">{a.desc}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      );

    /* ── DEEP DIVE (KINETIC / STOW / GHOST) ── */
    case 'deepdive':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-3">
            <Badge text={s.badge} />
            <h2 className="text-xl font-bold mt-1.5">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div className="space-y-4">
              <div className="grid grid-cols-2 gap-3">
                {s.stats.map((stat, i) => <StatCard key={i} {...stat} />)}
              </div>
              {s.flow && (
                <div className="space-y-2 mt-4">
                  <div className="text-[10px] font-mono text-gray-500 tracking-widest">DATA FLOW</div>
                  {s.flow.map((step, i) => (
                    <div key={i} className="flex items-start space-x-2">
                      <span className="text-cyan-600 font-mono text-xs mt-0.5">{i + 1}.</span>
                      <span className="text-gray-300 text-xs leading-snug">{step}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
            {s.cascade && (
              <div className="flex flex-col justify-center">
                <div className="text-[10px] font-mono text-gray-500 tracking-widest mb-3">POWER CASCADE</div>
                <div className="space-y-2">
                  {s.cascade.map((tier, i) => (
                    <div key={i} className="flex items-center space-x-3">
                      <div className={`w-14 text-right font-mono text-sm font-bold text-${tier.color}-400`}>{tier.pct}</div>
                      <div className="flex-1">
                        <div className={`h-8 bg-${tier.color}-900/30 border border-${tier.color}-700/40 rounded flex items-center px-3`}
                             style={{ width: `${100 - (i * 15)}%` }}>
                          <span className="text-xs text-gray-300 truncate">{tier.tier}</span>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
                <div className="mt-4 p-3 bg-emerald-900/10 border border-emerald-700/30 rounded text-xs text-emerald-300">
                  <strong>Key:</strong> Processes are <em>frozen</em> in memory via cgroup freezer. When power returns, they <em>thaw instantly</em>. No reboot. No data loss. No restart sequence.
                </div>
              </div>
            )}
          </div>
        </div>
      );

    /* ── MESH ── */
    case 'mesh':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-3">
            <Badge text="§3.2 Focus Area 2" color="emerald" />
            <h2 className="text-xl font-bold mt-1.5">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-1 md:grid-cols-2 gap-4 items-center">
            <div className="space-y-4">
              {s.items.map((item, i) => (
                <div key={i} className={`flex items-start space-x-3 bg-${item.color}-900/10 border border-${item.color}-700/30 rounded p-4`}>
                  <item.icon size={24} className={`text-${item.color}-400 flex-shrink-0 mt-0.5`} />
                  <div>
                    <div className={`text-${item.color}-400 font-bold text-sm mb-1`}>{item.label}</div>
                    <div className="text-gray-400 text-xs leading-relaxed">{item.desc}</div>
                  </div>
                </div>
              ))}
            </div>
            <TacticalFrame>
              <div className="h-full flex flex-col items-center justify-center p-6">
                <div className="flex flex-col items-center mb-4">
                  <div className="w-16 h-16 border-2 border-emerald-500 bg-emerald-900/20 rounded-full flex items-center justify-center animate-pulse" style={{ animationDuration: '3s' }}>
                    <Satellite size={28} className="text-emerald-400" />
                  </div>
                  <span className="text-emerald-400 text-[10px] font-mono mt-1">DRONE RELAY</span>
                  <span className="text-gray-600 text-[8px]">400ft AGL · 100km range</span>
                </div>
                <div className="w-[2px] h-12 bg-gradient-to-b from-emerald-500/60 to-cyan-500/60" />
                <div className="flex flex-col items-center my-2">
                  <div className="w-20 h-14 border-2 border-cyan-500 bg-cyan-900/20 flex items-center justify-center rounded">
                    <Cpu size={28} className="text-cyan-400" />
                  </div>
                  <span className="text-cyan-400 text-xs font-mono mt-1 font-bold">COMMAND HUB</span>
                  <span className="text-gray-500 text-[8px]">VITO + OTTO AI SITREPs</span>
                </div>
                <div className="flex items-center space-x-6 mt-4">
                  {[1,2,3,4,5].map(n => (
                    <div key={n} className="flex flex-col items-center">
                      <div className="w-4 h-4 bg-blue-500 rounded-full animate-ping" style={{ animationDelay: `${n * 0.3}s`, animationDuration: '2s' }} />
                      <span className="text-[7px] text-blue-400 font-mono mt-1">$25</span>
                    </div>
                  ))}
                </div>
                <span className="text-blue-400 text-[9px] font-mono mt-2">COIN NODES · LoRa 915MHz · GPS · IP67</span>
              </div>
            </TacticalFrame>
          </div>
        </div>
      );

    /* ── VALIDATION ── */
    case 'validation':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-3">
            <Badge text="Field Data" color="emerald" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-1 md:grid-cols-3 gap-4">
            <div className="md:col-span-2 grid grid-cols-3 gap-3">
              {s.metrics.map((m, i) => (
                <div key={i} className="bg-gray-900/60 border border-gray-700/50 rounded p-4 flex flex-col items-center text-center">
                  <m.icon size={20} className="text-cyan-500 mb-2" />
                  <div className="text-2xl font-bold text-emerald-400">{m.value}</div>
                  <div className="text-xs font-bold text-white mt-1">{m.label}</div>
                  <div className="text-[10px] text-gray-500 mt-0.5">{m.desc}</div>
                </div>
              ))}
            </div>
            <div>
              <TacticalFrame>
                <div className="p-4 h-full flex flex-col justify-center">
                  <div className="text-[10px] font-mono text-gray-500 tracking-widest mb-3">HARDWARE PLATFORM</div>
                  <div className="space-y-2.5 font-mono text-xs">
                    {Object.entries(s.hardware).map(([key, val]) => (
                      <div key={key} className="flex justify-between">
                        <span className="text-gray-500">{key}:</span>
                        <span className="text-cyan-300">{val}</span>
                      </div>
                    ))}
                  </div>
                  <div className="mt-6 pt-3 border-t border-gray-800">
                    <div className="text-emerald-400 text-xs font-bold mb-1">Validation Conditions:</div>
                    <div className="text-gray-500 text-[10px] space-y-1">
                      <div>✓ Active vibration (transit)</div>
                      <div>✓ Unconditioned thermal</div>
                      <div>✓ Variable renewable power</div>
                      <div>✓ Network outages</div>
                    </div>
                  </div>
                </div>
              </TacticalFrame>
            </div>
          </div>
        </div>
      );

    /* ── APPLICATIONS ── */
    case 'applications':
      return (
        <div className="h-full flex flex-col px-6 py-4">
          <div className="mb-3">
            <Badge text="Reconfigurability" color="purple" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-4 gap-3">
            {s.tiers.map((tier, i) => (
              <div key={i} className={`border border-${tier.color}-700/30 bg-${tier.color}-900/5 rounded overflow-hidden flex flex-col`}>
                <div className={`bg-${tier.color}-900/20 px-3 py-2 border-b border-${tier.color}-700/30`}>
                  <span className={`text-${tier.color}-400 text-[10px] font-mono font-bold tracking-wider`}>{tier.name}</span>
                </div>
                <div className="p-2 flex-1 space-y-1.5">
                  {tier.apps.map((app, j) => (
                    <div key={j} className="bg-gray-900/40 rounded px-2 py-1.5">
                      <div className="text-white text-[11px] font-bold">{app.code}</div>
                      <div className="text-gray-500 text-[9px]">{app.desc}</div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
          <div className="mt-2 text-center text-[10px] text-gray-600 font-mono">
            Same 8 core agents · Different cascade thresholds · Different telemetry sources · Satellite bus = Mission Profile 18
          </div>
        </div>
      );

    /* ── TRANSITION ── */
    case 'transition':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-3">
            <Badge text="Phase I Scope" color="yellow" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-2 gap-6">
            <div>
              <div className="flex items-center space-x-2 mb-3">
                <CheckCircle size={16} className="text-emerald-500" />
                <span className="text-emerald-400 text-sm font-bold font-mono">WHAT STAYS (Deployed)</span>
              </div>
              <div className="space-y-2">
                {s.keeps.map((item, i) => (
                  <div key={i} className="bg-emerald-900/10 border border-emerald-700/30 rounded p-3">
                    <div className="text-emerald-300 text-xs font-bold">{item.label}</div>
                    <div className="text-gray-500 text-[10px] mt-0.5">{item.desc}</div>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <div className="flex items-center space-x-2 mb-3">
                <Wrench size={16} className="text-yellow-500" />
                <span className="text-yellow-400 text-sm font-bold font-mono">WHAT ADAPTS (Phase I Work)</span>
              </div>
              <div className="space-y-2">
                {s.changes.map((item, i) => (
                  <div key={i} className="bg-yellow-900/10 border border-yellow-700/30 rounded p-3">
                    <div className="text-yellow-300 text-xs font-bold">{item.label}</div>
                    <div className="text-gray-500 text-[10px] mt-0.5">{item.desc}</div>
                  </div>
                ))}
              </div>
              <div className="mt-3 p-3 bg-cyan-900/10 border border-cyan-700/30 rounded">
                <div className="text-cyan-400 text-[10px] font-mono font-bold mb-1">UNIVERSITY PARTNER SCOPE</div>
                <div className="text-gray-400 text-[10px]">
                  Items above are the university's deliverables: orbital simulation (GMAT/STK), radiation modeling, thermal vacuum analysis, CONOPS co-authoring.
                </div>
              </div>
            </div>
          </div>
        </div>
      );

    /* ── PARTNERSHIP ── */
    case 'partnership':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-3">
            <Badge text="STTR Structure" color="blue" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-2 gap-6">
            <div className="border border-cyan-700/30 bg-cyan-900/5 rounded overflow-hidden flex flex-col">
              <div className="bg-cyan-900/20 px-4 py-3 border-b border-cyan-700/30">
                <div className="text-cyan-400 font-bold">{s.business.name}</div>
                <div className="text-white text-xs font-mono">{s.business.role}</div>
              </div>
              <div className="p-4 flex-1 space-y-2.5">
                {s.business.tasks.map((t, i) => (
                  <div key={i} className="flex items-start space-x-2">
                    <ArrowRight size={12} className="text-cyan-600 mt-0.5 flex-shrink-0" />
                    <span className="text-gray-300 text-xs">{t}</span>
                  </div>
                ))}
              </div>
            </div>
            <div className="border border-emerald-700/30 bg-emerald-900/5 rounded overflow-hidden flex flex-col">
              <div className="bg-emerald-900/20 px-4 py-3 border-b border-emerald-700/30">
                <div className="text-emerald-400 font-bold">{s.university.name}</div>
                <div className="text-white text-xs font-mono">Budget: {s.university.budget}</div>
              </div>
              <div className="p-4 flex-1 space-y-2.5">
                {s.university.tasks.map((t, i) => (
                  <div key={i} className="flex items-start space-x-2">
                    <ArrowRight size={12} className="text-emerald-600 mt-0.5 flex-shrink-0" />
                    <span className="text-gray-300 text-xs">{t}</span>
                  </div>
                ))}
              </div>
              <div className="px-4 py-3 bg-emerald-900/10 border-t border-emerald-700/30">
                <div className="text-emerald-300 text-xs font-bold text-center">University receives $75K–$100K for simulation & validation</div>
              </div>
            </div>
          </div>
          <div className="mt-4 text-center">
            <div className="inline-flex items-center space-x-4 bg-gray-900/60 border border-gray-700/50 rounded px-6 py-3">
              <div className="text-center">
                <div className="text-[9px] text-gray-500 font-mono">SAM.GOV</div>
                <div className="text-cyan-400 text-xs font-bold font-mono">INC-GSAFSD20703056</div>
              </div>
              <div className="w-[1px] h-8 bg-gray-700" />
              <div className="text-center">
                <div className="text-[9px] text-gray-500 font-mono">STTR TOPIC</div>
                <div className="text-cyan-400 text-xs font-bold font-mono">SF25D-T1201</div>
              </div>
              <div className="w-[1px] h-8 bg-gray-700" />
              <div className="text-center">
                <div className="text-[9px] text-gray-500 font-mono">AMAC VEHICLE</div>
                <div className="text-cyan-400 text-xs font-bold font-mono">FA865226R0001</div>
              </div>
            </div>
          </div>
        </div>
      );

    /* ── TIMELINE ── */
    case 'timeline':
      return (
        <div className="h-full flex flex-col px-6 py-5">
          <div className="mb-3">
            <Badge text="Acquisition Path" color="yellow" />
            <h2 className="text-2xl font-bold mt-2">{s.title}</h2>
            <p className="text-gray-400 text-xs mt-1">{s.subtitle}</p>
          </div>
          <div className="flex-1 grid grid-cols-2 gap-6">
            <div>
              <div className="text-[10px] font-mono text-gray-500 tracking-widest mb-3">STTR TIMELINE</div>
              <div className="space-y-4 relative">
                <div className="absolute left-[5px] top-3 bottom-3 w-[2px] bg-gray-800" />
                {s.milestones.map((m, i) => (
                  <div key={i} className="flex items-start space-x-4 relative">
                    <div className={`w-3 h-3 rounded-full border-2 flex-shrink-0 mt-0.5 z-10 ${m.status === 'upcoming' ? `border-${m.color}-500 bg-${m.color}-500 animate-pulse` : `border-${m.color}-600 bg-gray-950`}`} />
                    <div>
                      <div className={`text-${m.color}-400 font-mono text-xs font-bold`}>{m.date}</div>
                      <div className="text-gray-300 text-sm">{m.label}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <div className="text-[10px] font-mono text-gray-500 tracking-widest mb-3">ACQUISITION STRATEGY</div>
              <div className="space-y-3">
                {s.strategy.map((item, i) => (
                  <div key={i} className="bg-gray-900/60 border border-gray-700/50 rounded p-4">
                    <div className="flex items-center space-x-2 mb-1">
                      <Target size={14} className="text-cyan-500" />
                      <span className="text-cyan-400 text-xs font-bold">{item.label}</span>
                    </div>
                    <p className="text-gray-400 text-[11px] leading-snug">{item.desc}</p>
                  </div>
                ))}
              </div>
              <div className="mt-4 p-3 bg-cyan-900/10 border border-cyan-700/30 rounded">
                <div className="text-cyan-300 text-xs text-center">
                  <strong>Path:</strong> STTR Win → Verified Experience → AMAC IDIQ Seat → $10B Vehicle Access
                </div>
              </div>
            </div>
          </div>
        </div>
      );

    /* ── CLOSING ── */
    case 'closing':
      return (
        <div className="h-full flex flex-col items-center justify-center px-8 text-center">
          <div className="mb-6">
            <Satellite size={28} className="text-cyan-600 mx-auto mb-3" />
            <h2 className="text-2xl font-bold">{s.title}</h2>
            <p className="text-gray-400 text-sm mt-1">{s.subtitle}</p>
          </div>
          <div className="grid grid-cols-2 gap-4 max-w-2xl mb-8">
            {s.asks.map((ask, i) => (
              <div key={i} className="bg-gray-900/60 border border-gray-700/50 rounded p-4 text-left">
                <div className="flex items-center space-x-2 mb-2">
                  <ask.icon size={16} className="text-cyan-500" />
                  <span className="text-cyan-400 text-sm font-bold">{ask.label}</span>
                </div>
                <p className="text-gray-400 text-xs leading-relaxed">{ask.desc}</p>
              </div>
            ))}
          </div>
          <div className="border border-cyan-700/40 bg-cyan-900/10 rounded px-6 py-4 max-w-lg">
            <div className="text-lg font-bold text-white mb-1">{s.contact.name}</div>
            <div className="text-cyan-400 text-sm font-mono mb-1">{s.contact.title}</div>
            <div className="text-gray-400 text-xs mb-3">{s.contact.affiliation}</div>
            <div className="flex items-center justify-center space-x-6 text-xs font-mono">
              <span className="text-gray-300">{s.contact.email}</span>
              <span className="text-gray-600">·</span>
              <span className="text-gray-300">{s.contact.phone}</span>
            </div>
            <div className="mt-3 pt-3 border-t border-cyan-800/50 text-gray-500 text-[10px] font-mono">
              {s.contact.sam}
            </div>
          </div>
          <div className="mt-8 text-gray-600 text-[10px] font-mono">
            VITO: Sovereign Operational Technology for the Extreme Edge · © 2026 Tyler Eno
          </div>
        </div>
      );

    default:
      return null;
    }
  };

  /* ───────── MAIN LAYOUT ───────── */
  return (
    <div className="flex flex-col h-screen bg-black text-white font-sans overflow-hidden select-none">
      {/* Top Bar */}
      <div className="h-10 border-b border-gray-800/50 flex items-center justify-between px-4 bg-gray-950/90 backdrop-blur">
        <div className="flex items-center space-x-3">
          <Shield size={14} className="text-cyan-500" />
          <span className="font-bold tracking-wider text-[10px] text-gray-400 font-mono">
            VITO SERIES-4 · STTR SF25D-T1201 · ADAPTIVE & INTELLIGENT SPACE
          </span>
        </div>
        <div className="flex items-center space-x-4">
          <span className="text-gray-600 text-[10px] font-mono">{currentSlide + 1} / {totalSlides}</span>
          <button onClick={toggleNotes} className={`p-1 rounded transition-colors ${showNotes ? 'bg-cyan-900/50 text-cyan-400' : 'text-gray-600 hover:text-white'}`} title="Toggle speaker notes (N)">
            <BookOpen size={14} />
          </button>
        </div>
      </div>

      <div className="flex-1 flex overflow-hidden">
        <div className={`flex-1 relative transition-all duration-300 ${showNotes ? 'w-3/4' : 'w-full'}`}>
          <div className="h-full">{renderSlide()}</div>
          <button onClick={prevSlide} disabled={currentSlide === 0} className="absolute left-1 top-1/2 -translate-y-1/2 p-2 text-gray-700 hover:text-cyan-500 disabled:opacity-0 transition-all disabled:pointer-events-none">
            <ChevronLeft size={32} />
          </button>
          <button onClick={nextSlide} disabled={currentSlide === totalSlides - 1} className="absolute right-1 top-1/2 -translate-y-1/2 p-2 text-gray-700 hover:text-cyan-500 disabled:opacity-0 transition-all disabled:pointer-events-none">
            <ChevronRight size={32} />
          </button>
        </div>
        <div className={`${showNotes ? 'w-72 border-l border-gray-800/50' : 'w-0'} bg-gray-950 transition-all duration-300 overflow-hidden flex flex-col`}>
          <div className="p-4">
            <h3 className="text-cyan-700 font-mono text-[10px] mb-3 uppercase tracking-widest border-b border-gray-800 pb-2">Speaker Notes</h3>
            <div className="text-xs leading-relaxed text-gray-500">{currentSlideData.notes}</div>
          </div>
        </div>
      </div>

      {/* Slide Nav Dots */}
      <div className="h-8 bg-gray-950/90 border-t border-gray-800/50 flex items-center justify-center space-x-1.5 px-4">
        {slides.map((_, i) => (
          <button key={i} onClick={() => setCurrentSlide(i)} className={`w-1.5 h-1.5 rounded-full transition-all ${i === currentSlide ? 'bg-cyan-500 w-4' : 'bg-gray-700 hover:bg-gray-500'}`} />
        ))}
      </div>
    </div>
  );
};

export default SlideDeck;
