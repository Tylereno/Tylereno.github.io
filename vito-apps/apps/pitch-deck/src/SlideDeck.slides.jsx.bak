        { name: 'OTTO', role: 'Product Manager / AI', badge: 'MANAGER', desc: 'Local LLM inference, anomaly analysis, autonomous decision-making', color: 'emerald' },
        { name: 'MASON', role: 'Personnel Director', badge: 'HR', desc: 'Agent capability management, resource allocation, crew scaling', color: 'purple' },
      ],
      operations: [
