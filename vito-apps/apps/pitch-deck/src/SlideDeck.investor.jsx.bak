import React, { useState, useEffect, useCallback } from 'react';
import {
  ChevronRight,
  ChevronLeft,
  Radio,
  Zap,
  Activity,
  CheckCircle,
  Clock,
  Crosshair,
  Menu,
  Terminal,
  AlertTriangle,
  TrendingUp,
} from 'lucide-react';

const SlideDeck = () => {
  const [currentSlide, setCurrentSlide] = useState(0);
  const [showNotes, setShowNotes] = useState(false);

  const totalSlides = 10;

  const nextSlide = useCallback(() => {
    setCurrentSlide((s) => Math.min(s + 1, totalSlides - 1));
  }, []);

  const prevSlide = useCallback(() => {
    setCurrentSlide((s) => Math.max(s - 1, 0));
  }, []);

  const toggleNotes = useCallback(() => {
    setShowNotes((n) => !n);
  }, []);

  useEffect(() => {
    const handleKeyDown = (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ') {
        e.preventDefault();
        nextSlide();
      }
      if (e.key === 'ArrowLeft') prevSlide();
      if (e.key === 'n') toggleNotes();
    };
    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [nextSlide, prevSlide, toggleNotes]);

  const slides = [
    {
      id: 1,
      type: 'title',
      title: 'VITO',
      subtitle: "We don't pitch. We ship.",
      tagline:
        'Phase 2 GHOST messaging deployed Feb 12. 19 days early. 18 tests passing. Production ready.',
      visual: 'live-terminal',
      notes:
        "Open with the terminal showing GHOST running. This is not a concept. It's live code you can curl right now.",
    },
    {
      id: 2,
      type: 'standard',
      title: "THE PROBLEM ISN'T THEORETICAL",
      bullets: [
        'Wildfire crews lose comms beyond 1km.',
        "SAR teams can't query asset locations in canyons.",
        'Post-mission analysis is a body bag, not a tactic.',
        'We watched people die waiting for satellite uplinks.',
      ],
      visual: 'incident-report',
      notes:
        'This is personal. We watched real incidents where 15-second latency killed situational awareness. VITO is the tool we wish existed.',
    },
    {
      id: 3,
      type: 'standard',
      title: 'WHAT WE SHIPPED (NOT PLAN TO SHIP)',
      bullets: [
        '✅ GHOST bidirectional messaging (Feb 12, 2026)',
        '✅ @vito natural language queries over LoRa',
        '✅ 200-char sentence-boundary truncation',
        '✅ MQTT routing + Ollama LLM integration',
        '✅ Dashboard WebSocket at :8901 (LIVE NOW)',
      ],
      visual: 'test-results',
      notes:
        "Target was March 3. We delivered February 12. That's 19 days early. All 18 unit tests passing. 1500 stress-test iterations without failure.",
    },
    {
      id: 4,
      type: 'demo',
      title: 'LIVE OPERATOR EXPERIENCE',
      bullets: [
        "Operator keys radio: '@vito status grid 4'",
        'GHOST receives over LoRa mesh',
        'LLM processes telemetry in 2-3 seconds',
        "Response: 'Grid 4: Temp spike Node A. Vehicle fire probable. Reroute.'",
        'All air-gapped. No internet. No cloud.',
      ],
      visual: 'radio-exchange',
      notes:
        'This is not a mockup. You can test this right now. Any $50 LoRa radio. Military brevity. Instant answers. Zero AWS calls.',
    },
    {
      id: 5,
      type: 'standard',
      title: 'THE PHYSICS UNLOCK: TETHERED RELAY',
      bullets: [
        'Ground radios: 1km range (blocked by terrain)',
        'Tethered drone at 400ft: 50km range',
        'Power: 400V DC over Kevlar-reinforced cable',
        'Loiter time: Weeks, not 30-minute battery swaps',
        'Supplier RFQs submitted Feb 12 (Gore, Novacavi, Precision)',
      ],
      visual: 'tether-engineering',
      notes:
        "This isn't aspirational. We have the engineering specs. 600V DC insulation, ITU-T G.657 fiber, ≥500 lbf Kevlar. We're negotiating with real suppliers right now.",
    },
    {
      id: 6,
      type: 'standard',
      title: 'ARCHITECTURE: NO HAND-WAVING',
      bullets: [
        'Tier 1: Expendable LoRa sensor swarm ($30/node)',
        'Tier 2: Pelican Hub (Intel NUC + Ollama + MQTT)',
        'Tier 3: 400V tethered relay (infinite loiter)',
        'All telemetry processed edge-side with quantized LLMs',
        'Operators query via any LoRa radio (@vito syntax)',
      ],
      visual: 'system-diagram',
      notes:
        "Every component is spec'd, priced, and sourced. The software stack is containerized in Docker Compose. We parallelized long-lead procurement with sprint development.",
    },
    {
      id: 7,
      type: 'standard',
      title: 'ENGINEERING RIGOR, NOT SLIDES',
      bullets: [
        '18 unit tests (command parsing, deduplication, retry logic)',
        '1500 stress-test iterations (race conditions, timeouts)',
        'Sentence-boundary truncation (no mid-word LoRa cuts)',
        '5-second deduplication window per node+query hash',
        'Exponential backoff for Ollama timeouts',
      ],
      visual: 'code-quality',
      notes:
        "We don't write code and pray. We stress-test until it breaks, then fix the break. GHOST passed 1500 iterations without a single dropped command.",
    },
    {
      id: 8,
      type: 'standard',
      title: "GO-TO-MARKET: WE DON'T WAIT FOR DoD",
      bullets: [
        'Beachhead: California wildfire agencies (Q3 pilots)',
        'Secondary: SAR teams in Pacific Northwest',
        'Tertiary: Private resource extraction (oil/gas dead zones)',
        'Why they\'ll pay: People die when comms fail',
        'Revenue model: $15k upfront + $2k/mo HaaS',
      ],
      visual: 'customer-pipeline',
      notes:
        "We're not waiting for 24-month DoD procurement cycles. State agencies have discretionary budgets and real pain points right now.",
    },
    {
      id: 9,
      type: 'standard',
      title: 'TIMELINE: PHASE 2 → PHASE 3',
      bullets: [
        'Feb 14: Tether cable RFQs due (submitted)',
        'Feb 21-24: Supplier responses + validation',
        'Mar 3: Heltec LoRa boards integrated + live packets',
        'May-Jun: Tether cable delivery + assembly',
        'Q3 2026: First pilot deployments (California)',
      ],
      visual: 'gantt',
      notes:
        "This is not a 5-year moonshot. We're manufacturing-ready by May. Field-ready by Q3. We know this because we already built the hard part: the software.",
    },
    {
      id: 10,
      type: 'contact',
      title: 'THE ASK',
      bullets: [
        'Raising: $450k seed (covers tether manufacturing + ruggedization)',
        'Use of funds: 10 tether systems @ $25k ea, PCB runs, Q3 pilot support',
        'Traction: GHOST live, supplier RFQs out, state agency conversations active',
        'Exit: Acquisition by defense prime or IPO after govt contract scale',
      ],
      visual: 'contact-block',
      notes:
        "We're not asking you to bet on an idea. We're asking you to fund the manufacturing of a working system. The code is live. The timeline is locked. The customers are waiting.",
    },
  ];

  const currentSlideData = slides[currentSlide];

  const TacticalFrame = ({ children, className = '' }) => (
    <div
      className={`relative w-full h-full border-2 border-gray-700 bg-gray-950 overflow-hidden ${className}`}
