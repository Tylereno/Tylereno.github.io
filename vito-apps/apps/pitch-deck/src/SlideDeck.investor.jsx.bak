              </div>
              <div className="text-gray-400 text-[10px] ml-2">
                · Sentence-boundary truncation (no word splits)
              </div>
              <div className="text-gray-400 text-[10px] ml-2">
                · Ollama timeout retry (exponential backoff)
              </div>
            </div>
          </div>
