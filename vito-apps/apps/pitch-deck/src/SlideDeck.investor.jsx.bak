              ))}
            </div>
            <div className="mt-6 pt-4 border-t border-gray-700 text-blue-400">
              <div>STRESS TEST: 1500 iterations</div>
              <div className="text-gray-500">
                No dropped commands. No race conditions.
              </div>
            </div>
          </div>
