      case 'test-results':
        return (
          <div className="bg-gray-900 h-full w-full p-6 font-mono flex flex-col justify-center">
            <div className="flex items-center space-x-2 mb-4 text-emerald-400">
              <CheckCircle size={24} />
              <span className="text-xl font-bold">TEST SUITE: PASSING</span>
            </div>
            <div className="space-y-1 text-xs">
              {[
                'test_command_detection_regex ✓',
                'test_200_char_truncation ✓',
                'test_sentence_boundary_split ✓',
                'test_mqtt_routing ✓',
                'test_ollama_timeout_retry ✓',
                'test_deduplication_window ✓',
                'test_builtin_commands (ping/status/ack) ✓',
                'test_websocket_history ✓',
              ].map((test, idx) => (
                <div key={idx} className="text-emerald-500">
