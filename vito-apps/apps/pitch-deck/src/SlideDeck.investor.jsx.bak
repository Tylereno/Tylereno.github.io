            <div className="flex items-start space-x-3 mb-4">
              <AlertTriangle className="text-red-500 flex-shrink-0" size={32} />
              <div>
                <h3 className="text-red-400 font-bold text-lg mb-1">
                  INCIDENT REPORT
                </h3>
                <div className="text-gray-400 text-sm font-mono">
                  2024-08-15 // CALDOR FIRE
                </div>
              </div>
            </div>
            <div className="space-y-2 text-gray-300 text-sm border-l-2 border-red-800 pl-4">
              <p>&quot;Lost radio contact with Strike Team 2 at 14:23.&quot;</p>
              <p>&quot;Satellite uplink showed 18s latency.&quot;</p>
              <p>
                &quot;By the time we got coordinates, fire had jumped the
                line.&quot;
              </p>
              <p className="text-red-400 font-bold mt-4">
                &quot;Real-time intel would have saved the evacuation.&quot;
              </p>
            </div>
          </div>
