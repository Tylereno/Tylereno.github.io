                    <h1 className="text-7xl md:text-9xl font-black tracking-tighter leading-none">
                      {currentSlideData.title}
                    </h1>
                    <h2 className="text-2xl md:text-3xl text-emerald-500 font-bold tracking-tight">
                      {currentSlideData.subtitle}
                    </h2>
                    <p className="text-gray-300 text-lg md:text-xl border-l-4 border-emerald-600 pl-4 leading-relaxed font-light">
                      {currentSlideData.tagline}
                    </p>
                  </div>
                  <div className="h-80 md:h-full">
                    <TacticalFrame>
                      {renderVisual(currentSlideData.visual)}
                    </TacticalFrame>
                  </div>
                </div>
              ) : currentSlideData.type === 'demo' ? (
                <div className="grid grid-cols-1 md:grid-cols-5 gap-8 h-full items-center">
                  <div className="md:col-span-2 space-y-5">
                    <h2 className="text-4xl md:text-5xl font-black uppercase tracking-tight border-b-2 border-emerald-600 pb-3">
                      {currentSlideData.title}
                    </h2>
                    {currentSlideData.bullets &&
                      currentSlideData.bullets.map((bullet, idx) => (
                        <div key={idx} className="flex items-start space-x-3">
                          <div className="mt-2 min-w-[6px] h-1.5 w-1.5 bg-emerald-500 rounded-full" />
                          <p className="text-base md:text-lg text-gray-300 leading-snug font-light">
                            {bullet}
                          </p>
                        </div>
                      ))}
                  </div>
                  <div className="md:col-span-3 h-96 md:h-full">
                    <TacticalFrame>
                      {renderVisual(currentSlideData.visual)}
                    </TacticalFrame>
                  </div>
                </div>
              ) : (
                <div className="flex flex-col h-full">
                  <div className="mb-6 border-b-2 border-gray-700 pb-4">
                    <h2 className="text-4xl md:text-5xl font-black uppercase tracking-tight">
                      {currentSlideData.title}
                    </h2>
                  </div>
                  <div className="flex-1 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                    <div className="space-y-5">
                      {currentSlideData.bullets &&
                        currentSlideData.bullets.map((bullet, idx) => (
                          <div
                            key={idx}
                            className="flex items-start space-x-3 group"
                          >
                            <div className="mt-1.5 min-w-[8px] h-2 w-2 bg-emerald-600 group-hover:bg-emerald-400 transition-colors" />
                            <p className="text-lg md:text-xl text-gray-300 font-light leading-snug group-hover:text-white transition-colors">
                              {bullet}
                            </p>
                          </div>
                        ))}
                    </div>
                    <div className="h-80 md:h-full w-full">
                      <TacticalFrame>
                        {renderVisual(currentSlideData.visual)}
                      </TacticalFrame>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>

          {/* Navigation */}
          <button
            onClick={prevSlide}
            disabled={currentSlide === 0}
            className="absolute left-2 top-1/2 -translate-y-1/2 p-3 text-gray-700 hover:text-emerald-500 disabled:opacity-0 transition-all disabled:pointer-events-none"
          >
            <ChevronLeft size={40} />
          </button>
          <button
            onClick={nextSlide}
            disabled={currentSlide === totalSlides - 1}
            className="absolute right-2 top-1/2 -translate-y-1/2 p-3 text-gray-700 hover:text-emerald-500 disabled:opacity-0 transition-all disabled:pointer-events-none"
          >
            <ChevronRight size={40} />
          </button>
        </div>

        {/* Speaker Notes Panel */}
        <div
          className={`${showNotes ? 'w-80 border-l border-gray-800' : 'w-0'} bg-gray-950 transition-all duration-300 overflow-hidden flex flex-col`}
        >
          <div className="p-6">
            <h3 className="text-emerald-600 font-mono text-xs mb-4 uppercase tracking-widest border-b border-gray-800 pb-2">
              Speaker Notes
            </h3>
            <div className="text-sm leading-relaxed text-gray-400 font-light">
              {currentSlideData.notes}
            </div>
          </div>
        </div>
      </div>

      {/* Progress Bar */}
      <div className="h-1 bg-gray-900">
        <div
          className="h-full bg-emerald-600 transition-all duration-300"
          style={{
            width: `${((currentSlide + 1) / totalSlides) * 100}%`,
          }}
        />
      </div>
    </div>
  );
};

export default SlideDeck;
