            <Menu size={16} />
          </button>
        </div>
      </div>

      <div className="flex-1 flex overflow-hidden">
        {/* Main Slide Area */}
        <div
          className={`flex-1 relative flex flex-col transition-all duration-300 ${showNotes ? 'w-2/3' : 'w-full'}`}
