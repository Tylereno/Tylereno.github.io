      case 'radio-exchange':
        return (
          <div className="h-full w-full bg-gray-900 p-4 flex flex-col justify-center space-y-4">
            <div className="bg-blue-900/30 border border-blue-700 p-3 rounded self-end max-w-[80%]">
              <div className="text-blue-300 text-xs font-mono mb-1">
                OPERATOR [14:32:18]
              </div>
              <div className="text-white">@vito status grid 4</div>
            </div>
            <div className="flex items-center justify-center space-x-2 text-gray-600">
              <div className="w-2 h-2 bg-emerald-500 rounded-full animate-pulse" />
              <span className="text-xs font-mono">PROCESSING (2.3s)</span>
              <div className="w-2 h-2 bg-emerald-500 rounded-full animate-pulse" />
            </div>
            <div className="bg-emerald-900/30 border border-emerald-700 p-3 rounded self-start max-w-[85%]">
              <div className="text-emerald-300 text-xs font-mono mb-1">
                VITO [14:32:21]
              </div>
              <div className="text-white text-sm leading-snug">
                Grid 4: Temp spike Node A (450°C). High prob vehicle fire. Wind
                270@15. Recommend reroute SE via Grid 6.
              </div>
            </div>
            <div className="text-gray-600 text-xs font-mono text-center mt-4">
              ● AIR-GAPPED · NO INTERNET · NO CLOUD
            </div>
          </div>
        );

      case 'tether-engineering':
        return (
          <div className="h-full w-full bg-gray-900 p-6 flex flex-col justify-center">
            <div className="border-2 border-yellow-600/50 bg-yellow-900/10 p-4">
              <div className="flex items-center space-x-2 text-yellow-400 mb-3">
                <Zap size={20} />
                <h3 className="font-bold text-lg">TETHER SPECIFICATIONS</h3>
              </div>
              <div className="space-y-2 text-sm font-mono">
                {[
                  ['Voltage:', '600V DC insulation'],
                  ['Data:', 'ITU-T G.657 fiber optic'],
                  ['Strength:', '≥500 lbf Kevlar'],
                  ['Length:', '400ft (122m)'],
                  ['OD Tolerance:', '±0.2mm'],
                ].map(([label, value], idx) => (
                  <div key={idx} className="flex justify-between">
                    <span className="text-gray-400">{label}</span>
                    <span className="text-white">{value}</span>
                  </div>
                ))}
              </div>
              <div className="mt-4 pt-3 border-t border-yellow-900 text-xs text-gray-400">
                RFQs submitted Feb 12 → Gore, Novacavi, Precision
                <br />
                Expected quotes: Feb 21-24
              </div>
            </div>
          </div>
        );

      case 'system-diagram':
        return (
          <div className="h-full w-full flex items-center justify-center p-4">
            <div className="relative w-full max-w-md h-80">
              {/* Drone */}
              <div className="absolute top-0 left-1/2 -translate-x-1/2 flex flex-col items-center">
                <div
                  className="w-16 h-16 border-2 border-emerald-500 bg-emerald-900/20 rounded-full flex items-center justify-center animate-bounce"
                  style={{ animationDuration: '3s' }}
                >
                  <Radio size={28} className="text-emerald-400" />
                </div>
                <span className="text-emerald-400 text-[10px] font-mono mt-1">
                  TIER 3 RELAY
                </span>
                <span className="text-gray-600 text-[8px]">
                  400ft · 50km range
                </span>
              </div>

              {/* Tether */}
              <div className="absolute top-20 left-1/2 -translate-x-1/2 w-1 h-24 bg-gradient-to-b from-emerald-500/50 to-yellow-500/50" />

              {/* Hub */}
              <div className="absolute top-48 left-1/2 -translate-x-1/2 flex flex-col items-center">
                <div className="w-20 h-16 border-2 border-white bg-gray-800 flex items-center justify-center">
                  <Activity size={32} className="text-white" />
                </div>
                <span className="text-white text-xs font-mono mt-1 font-bold">
                  TIER 2 HUB
                </span>
                <span className="text-gray-500 text-[8px]">
                  Ollama + MQTT
                </span>
              </div>

              {/* Sensors */}
              <div className="absolute top-52 left-8 w-3 h-3 bg-blue-500 rounded-full animate-ping" />
              <div
                className="absolute top-48 right-12 w-3 h-3 bg-blue-500 rounded-full animate-ping"
                style={{ animationDelay: '0.3s' }}
              />
              <div
                className="absolute top-60 right-8 w-3 h-3 bg-blue-500 rounded-full animate-ping"
                style={{ animationDelay: '0.6s' }}
              />
              <div className="absolute top-56 left-4 text-[8px] text-blue-400 font-mono">
                TIER 1
              </div>
            </div>
          </div>
        );

      case 'code-quality':
        return (
          <div className="bg-black h-full w-full p-4 font-mono text-xs flex flex-col justify-center">
            <div className="text-emerald-500 mb-3 text-sm font-bold">
              services/mesh-gateway/tests/
            </div>
            <div className="space-y-1 text-[10px]">
              <div className="text-gray-500">
                // Stress test: concurrent command flooding
              </div>
              <div className="text-white">
                for (let i = 0; i &lt; 1500; i++) {'{'}
              </div>
              <div className="text-white ml-4">
                await simulateRadioCommand();
              </div>
              <div className="text-white ml-4">assert(noDuplicates());</div>
              <div className="text-white ml-4">
                assert(allCommandsProcessed());
              </div>
              <div className="text-white">{'}'};</div>
              <div className="mt-3 text-emerald-400">
                ✓ 1500 iterations · 0 failures
              </div>
            </div>
            <div className="mt-6 pt-3 border-t border-gray-800">
