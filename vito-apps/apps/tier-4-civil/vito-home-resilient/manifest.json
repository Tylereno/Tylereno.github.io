{
  "program": "ark-home-resilient",
  "tier": "TIER 4 - Civil & Lifestyle",
  "codename": "HOME",
  "category": "Smart Home / Residential",
  "version": "4.6.6",
  "description": "Resilient smart home without ISP dependency. Operates fully offline.",
  "challenge": "Smart homes relying on cloud-based automation fail during ISP outages. Users lose control of lighting, temperature, security, and other critical systems.",
  "response": "VITO enables all automation rules to execute locally without cloud dependency. Learn household routines, adapt to schedule changes, and maintain security entirely offline.",
  "result": "Uninterrupted smart home operation, zero external dependency, and complete user privacy.",
  "agents_enabled": ["VIGIL", "STOW", "GHOST", "OTTO"],
  "agents_disabled": ["KINETIC", "FORGE"],
  "key_capabilities": [
    "Local automation execution",
    "Routine learning + adaptation",
    "Offline security management",
    "Energy optimization",
    "Complete privacy (no cloud)"
  ],
  "power_behavior": {
    "100_percent": "Full smart home features",
    "50_percent": "Essential automation only",
    "25_percent": "Security + climate control",
    "10_percent": "Graceful shutdown"
  },
  "dependencies": {
    "vito-core": "4.6.6",
    "node": "^18.0.0"
  },
  "ports": {
    "api": 3001,
    "home_automation": 3021,
    "security_gateway": 3022,
    "mesh": 41641
  },
  "volumes": {
    "automation_rules": "/data/rules",
    "routines": "/data/routines",
    "nvme_cache": "/data/stow"
  },
  "environment_variables": {
    "OTTO_LOCAL_AUTOMATION_ONLY": "true",
    "OTTO_ROUTINE_LEARNING": "true",
    "OTTO_ENERGY_OPTIMIZATION": "true",
    "STOW_SECURITY_LOGGING": "true",
    "VIGIL_SECURITY_MONITORING": "true"
  }
}
